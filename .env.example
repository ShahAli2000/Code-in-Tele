# Copy to .env and fill in real values. NEVER commit .env.
# .gitignore already excludes .env (see ".env.*" / "!.env.example").

# ---- Telegram ----------------------------------------------------------------
# Bot token from @BotFather. Looks like "123456789:ABCdef...".
TELEGRAM_BOT_TOKEN=

# Numeric chat ID of the supergroup with topics enabled. Negative integer,
# typically of the form -1001234567890. See README "Phase -1" for how to fetch.
TELEGRAM_CHAT_ID=

# Comma-separated list of Telegram user IDs allowed to use the bot.
# Anyone not listed is silently rejected. See README for how to fetch your ID.
TELEGRAM_ALLOWED_USER_IDS=

# ---- Anthropic ---------------------------------------------------------------
# API key from https://platform.claude.com/. Begins with "sk-ant-".
# Alternative: leave blank and run `claude login` on this machine to use the
# bundled CLI's Pro/Max OAuth credentials. The SDK will use whichever it finds.
ANTHROPIC_API_KEY=

# ---- Bridge internals --------------------------------------------------------
# Shared secret for HMAC-signing envelopes between bridge and runners over
# Tailscale. Any random 32+ char string. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
BRIDGE_HMAC_SECRET=

# Where the SQLite store lives. Created on first run.
CT_DB_PATH=./state/ct.db

# Where the local runner listens. Bridge connects here for in-process Phase 0/2.
CT_RUNNER_HOST=127.0.0.1
CT_RUNNER_PORT=8765

# ---- Observability -----------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR.
CT_LOG_LEVEL=INFO

# Set to "json" for structured logs, "console" for human-readable.
CT_LOG_FORMAT=console
