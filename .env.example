# Copy to .env and fill in real values. NEVER commit .env.
# .gitignore already excludes .env (see ".env.*" / "!.env.example").

# ---- Telegram ----------------------------------------------------------------
# Bot token from @BotFather. Looks like "123456789:ABCdef...".
TELEGRAM_BOT_TOKEN=

# Numeric chat ID of the supergroup with topics enabled. Negative integer,
# typically of the form -1001234567890. See README "Phase -1" for how to fetch.
TELEGRAM_CHAT_ID=

# Comma-separated list of Telegram user IDs allowed to use the bot.
# Anyone not listed is silently rejected. See README for how to fetch your ID.
TELEGRAM_ALLOWED_USER_IDS=

# ---- Anthropic ---------------------------------------------------------------
# Two ways to authenticate (pick one):
#
#   1. Pro/Max OAuth (no token spend on top of subscription, recommended if
#      you have Pro/Max). Leave ANTHROPIC_API_KEY blank, then run on the
#      runner host:
#          curl -fsSL https://claude.ai/install.sh | bash
#          claude            # then /login in the prompt
#      The SDK picks up the OAuth credentials from your keychain.
#
#   2. API key (pay per token; works without a subscription). Set the value
#      below to a key from https://platform.claude.com/ (begins "sk-ant-").
#
# The SDK uses whichever it finds. If both are present, the API key wins.
ANTHROPIC_API_KEY=

# ---- Bridge internals --------------------------------------------------------
# Shared secret for HMAC-signing envelopes between bridge and runners over
# Tailscale. Any random 32+ char string. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
BRIDGE_HMAC_SECRET=

# Where the SQLite store lives. Created on first run.
CT_DB_PATH=./state/ct.db

# Where the local runner listens. Bridge connects here for the in-process
# (single-host) deployment. On a runner-only host (laptop/secondary mac/Linux
# box), set CT_RUNNER_HOST=<this host's tailnet IP> so the bridge on the
# always-on host can reach it.
CT_RUNNER_HOST=127.0.0.1
CT_RUNNER_PORT=8765

# Idle-session reaper (runner side). A ClaudeSDKClient holds a long-lived CLI
# subprocess (~170MB RSS) for fast turn-to-turn context. Sessions left silent
# this long are closed; the bridge keeps the DB row and /resume re-opens with
# resume=sdk_session_id. Set to 0 to disable. Reaper polls every
# CT_REAPER_INTERVAL_S seconds.
CT_IDLE_REAP_MINUTES=30
CT_REAPER_INTERVAL_S=60

# ---- Web dashboard -----------------------------------------------------------
# When CT_DASHBOARD_HOST is unset (the default), the bridge probes
# `tailscale ip -4` at boot and binds to the tailnet IP — reachable from
# your phone or laptop on the tailnet, but not exposed to the LAN.
# Set explicitly to 127.0.0.1 for loopback-only (use /tunnel for off-tailnet
# access), or 0.0.0.0 to bind every interface (NOT recommended).
CT_DASHBOARD_HOST=
CT_DASHBOARD_PORT=8766

# ---- Observability -----------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR.
CT_LOG_LEVEL=INFO

# Set to "json" for structured logs, "console" for human-readable.
CT_LOG_FORMAT=console
